AST_MANAGER_ADMIN_WRITE=system,call,originate
RPT_START_PORT=10000
RPT_END_PORT=10100
TLS_CERTFILE=/etc/asterisk/keys/fullchain.pem
TLS_PRIVATEKEY=/etc/asterisk/keys/privkey.pem